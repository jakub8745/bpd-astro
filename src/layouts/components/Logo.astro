---
import { Image } from "astro:assets";
import config from "@/config/config.json";
const { src } = Astro.props;
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;
---

<a href="/" class="navbar-brand block flex justify-center items-center h-full mt-4 mb-8">
  {
    src || logo ? (
      <Image
        width={logo_width.replace("px", "") * 2}
        height={logo_height.replace("px", "") * 2}
        src={src ? src : logo}
        alt={title}
        class="w-24 h-auto sm:w-32 sm:h-auto md:w-40 md:h-auto lg:w-48 lg:h-auto"
        style={{
          width: logo_width.replace("px", "") + "px",
        }}
      />
    ) : logo_text ? (
      <span class="text-xl sm:text-2xl md:text-3xl lg:text-4xl">{logo_text}</span>
    ) : (
      <span class="text-xl sm:text-2xl md:text-3xl lg:text-4xl">{title}</span>
    )
  }
</a>
